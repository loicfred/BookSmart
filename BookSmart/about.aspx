<%@ Page Title="" Language="C#" MasterPageFile="~/MainLayout.Master" AutoEventWireup="true" CodeBehind="about.aspx.cs" Inherits="BookSmart.about" %>
<asp:Content ID="Content1" ContentPlaceHolderID="MASTERHEAD" runat="server">
    <title>About Us | BookSmart</title>
</asp:Content>
<asp:Content ID="Content2" ContentPlaceHolderID="MASTERCONTENT" runat="server">
    <div class="about-container" style="max-width: 800px; margin: auto; padding: 40px 20px; font-family: Arial, sans-serif;">
        <h1 style="color: #333;">Who are we?</h1>
        <p style="font-size: 16px; color: #555; line-height: 1.6;">
            Welcome to <strong>BookSmart</strong>, your best place to discover new knowledge and world of wonders!
        </p>
        <p style="font-size: 16px; color: #555; line-height: 1.6;">
            Founded in 2025, BookSmart is an independent bookstore with the goal to connect readers with stories that inspire, inform, and entertain as well as books to expand your knowledge and wisdom.
            Whether you’re looking for the latest bestsellers, rare literary gems, or timeless classics, we offer a great selection for every kind of reader.
        </p>
        <h3 style="color: #444; margin-top: 30px;">Our Mission</h3>
        <p style="font-size: 16px; color: #555; line-height: 1.6;">
            We believe that books can change lives. Our mission is to provide an easy access for reading by providing a welcoming space where people of all ages and backgrounds can discover their next great read.
        </p>
        <h3 style="color: #444; margin-top: 30px;">What We Offer</h3>
        <ul style="font-size: 16px; color: #555; line-height: 1.6;">
            <li>Wide selection of fiction, non-fiction, and academic books.</li>
            <li>Local author highlights and indie books.</li>
            <li>Reading clubs and community events.</li>
            <li>Personalized book recommendations.</li>
        </ul>
        <h3 style="color: #444; margin-top: 30px;">Visit Us</h3>
        <p style="font-size: 16px; color: #555; line-height: 1.6;">
            Whether you shop online or visit our cozy location, you’ll find a passionate team of book lovers ready to help you explore the world one page at a time.
        </p>
        <p style="font-size: 16px; color: #555; line-height: 1.6;">
            Thank you for being a part of the BookSmart community!
        </p>
        <h3 style="color: #444; margin-top: 30px;">Contact Information</h3>
        <ul style="font-size: 16px; color: #555; line-height: 1.6;">
            <li>Email: support@booksmart.com.</li>
            <li>Phone: +230 5123 4567.</li>
            <li>Address: 123 Labourdonnais St, Port-Louis, Mauritius.</li>
        </ul>
    </div>
</asp:Content>
